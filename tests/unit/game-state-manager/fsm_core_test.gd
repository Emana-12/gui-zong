	_manager.change_state(GameStateManager.State.INTERMISSION)

	var result: bool = _manager.change_state(GameStateManager.State.DEATH)

	assert_bool(result).is_true()
	assert_int(_manager.get_current_state()) \
		.is_equal(GameStateManager.State.DEATH)


## =========================================================================
## 额外边界测试: 完整状态循环
## TITLE→COMBAT→DEATH→wait→RESTART→COMBAT→DEATH→wait→RESTART→COMBAT
## =========================================================================
func test_full_state_cycle() -> void:
	# TITLE→COMBAT
	assert_bool(_manager.change_state(GameStateManager.State.COMBAT)).is_true()
	assert_int(_manager.get_current_state()).is_equal(GameStateManager.State.COMBAT)

	# COMBAT→DEATH
	assert_bool(_manager.change_state(GameStateManager.State.DEATH)).is_true()
	assert_int(_manager.get_current_state()).is_equal(GameStateManager.State.DEATH)

	# 等待死亡延迟
	await get_tree().create_timer(_manager.death_delay + 0.05).timeout

	# DEATH→RESTART→COMBAT (自动)
	assert_bool(_manager.change_state(GameStateManager.State.RESTART)).is_true()
	assert_int(_manager.get_current_state()).is_equal(GameStateManager.State.COMBAT)

	# 第二次循环
	assert_bool(_manager.change_state(GameStateManager.State.DEATH)).is_true()
	await get_tree().create_timer(_manager.death_delay + 0.05).timeout
	assert_bool(_manager.change_state(GameStateManager.State.RESTART)).is_true()
	assert_int(_manager.get_current_state()).is_equal(GameStateManager.State.COMBAT)


## =========================================================================
## 额外边界测试: INTERMISSION 期间可以死亡
## =========================================================================
func test_combat_to_intermission_allowed() -> void:
	_manager.change_state(GameStateManager.State.COMBAT)
	var result: bool = _manager.change_state(GameStateManager.State.INTERMISSION)

	assert_bool(result).is_true()
	assert_int(_manager.get_current_state()) \
		.is_equal(GameStateManager.State.INTERMISSION)
