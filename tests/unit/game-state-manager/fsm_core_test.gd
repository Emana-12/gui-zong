## =========================================================================
## AC-8: 信号在同一帧内到达所有监听系统
## =========================================================================
func test_signal_arrives_same_frame() -> void:
	var listener_a_received: bool = false
	var listener_b_received: bool = false
	var listener_c_received: bool = false

	_manager.state_changed.connect(func(_old_s: GameStateManager.State, _new_s: GameStateManager.State) -> void:
		listener_a_received = true
	)
	_manager.state_changed.connect(func(_old_s: GameStateManager.State, _new_s: GameStateManager.State) -> void:
		listener_b_received = true
	)
	_manager.state_changed.connect(func(_old_s: GameStateManager.State, _new_s: GameStateManager.State) -> void:
		listener_c_received = true
	)

	# 触发状态转换
	_manager.change_state(GameStateManager.State.COMBAT)

	# 同一帧内所有监听器都应收到
	assert_bool(listener_a_received).is_true()
	assert_bool(listener_b_received).is_true()
	assert_bool(listener_c_received).is_true()


## =========================================================================
## AC-Edge: 死亡优先级覆盖测试
## 模拟同帧竞争：在 INTERMISSION 状态下，DEATH 转换应成功
