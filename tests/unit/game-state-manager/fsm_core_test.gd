extends GdUnitTestSuite

## 测试用 GameStateManager 实例
var _manager: GameStateManager


func before_test() -> void:
	_manager = auto_free(GameStateManager.new())
	# death_delay 设为极短，避免真实等待
	_manager.death_delay = 0.01
	# 手动触发 _ready 逻辑（因为是 auto_free，需模拟 _ready）
	_manager._ready()


## =========================================================================
## AC-1: 游戏启动初始化完成后，当前状态为 TITLE
## =========================================================================
func test_initial_state_is_title() -> void:
	assert_int(_manager.get_current_state()) \
		.is_equal(GameStateManager.State.TITLE)


## =========================================================================
## AC-2: TITLE→COMBAT 转换发出 state_changed(TITLE, COMBAT) 信号，返回 true
## =========================================================================
func test_title_to_combat_emits_signal() -> void:
	var signal_monitor := monitor_signals(_manager)
	var result: bool = _manager.change_state(GameStateManager.State.COMBAT)

	assert_bool(result).is_true()
	assert_int(_manager.get_current_state()) \
		.is_equal(GameStateManager.State.COMBAT)

	# 验证信号参数
	await assert_signal(signal_monitor).is_emitted("state_changed")


## =========================================================================
## AC-3: COMBAT→DEATH 转换发出 state_changed(COMBAT, DEATH) 信号
## =========================================================================
func test_combat_to_death_emits_signal() -> void:
	var signal_monitor := monitor_signals(_manager)

	# 先转到 COMBAT
	_manager.change_state(GameStateManager.State.COMBAT)
	# 再转到 DEATH
	var result: bool = _manager.change_state(GameStateManager.State.DEATH)

	assert_bool(result).is_true()
	assert_int(_manager.get_current_state()) \
		.is_equal(GameStateManager.State.DEATH)

	await assert_signal(signal_monitor).is_emitted("state_changed")


## =========================================================================
## AC-4: DEATH 状态下 death_delay 完成后 change_state(RESTART)
## 触发两次信号 (DEATH→RESTART, RESTART→COMBAT)，最终状态 COMBAT
## =========================================================================
func test_death_delay_then_restart_emits_two_signals() -> void:
	# 进入 DEATH
	_manager.change_state(GameStateManager.State.COMBAT)
	_manager.change_state(GameStateManager.State.DEATH)

	# 等待 death_delay 完成
	await get_tree().create_timer(_manager.death_delay + 0.05).timeout

	# 收集信号
	var received_signals: Array = []
	_manager.state_changed.connect(func(old_s: GameStateManager.State, new_s: GameStateManager.State) -> void:
		received_signals.append([old_s, new_s])
	)

	# 触发 RESTART
	var result: bool = _manager.change_state(GameStateManager.State.RESTART)

	assert_bool(result).is_true()
	assert_int(_manager.get_current_state()) \
		.is_equal(GameStateManager.State.COMBAT)

	# 验证两次信号
	assert_int(received_signals.size()).is_equal(2)
	# 第一次: DEATH→RESTART
	assert_int(received_signals[0][0]).is_equal(GameStateManager.State.DEATH)
	assert_int(received_signals[0][1]).is_equal(GameStateManager.State.RESTART)
	# 第二次: RESTART→COMBAT
	assert_int(received_signals[1][0]).is_equal(GameStateManager.State.RESTART)
	assert_int(received_signals[1][1]).is_equal(GameStateManager.State.COMBAT)


## =========================================================================
## AC-5: DEATH 状态下 death_delay 未完成时 change_state(RESTART)
## 返回 false，状态保持 DEATH，不发出信号
## =========================================================================
func test_death_delay_not_elapsed_restart_rejected() -> void:
	_manager.change_state(GameStateManager.State.COMBAT)
	_manager.change_state(GameStateManager.State.DEATH)

	# 不等待 delay，立即尝试 RESTART
	var received_signals: Array = []
	_manager.state_changed.connect(func(old_s: GameStateManager.State, new_s: GameStateManager.State) -> void:
		received_signals.append([old_s, new_s])
	)

	var result: bool = _manager.change_state(GameStateManager.State.RESTART)

	assert_bool(result).is_false()
	assert_int(_manager.get_current_state()) \
		.is_equal(GameStateManager.State.DEATH)
	assert_int(received_signals.size()).is_equal(0)


